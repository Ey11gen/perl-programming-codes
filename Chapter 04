#!/usr/bin/perl
use strict;
use warnings;

my $line = "data value\n";

print "Before chomp: [" . $line . "]\n";
chomp($line);
print "After chomp:  [" . $line . "]\n";

my $no_newline = "clean string";
chomp($no_newline);
print "Chomped no-newline: [" . $no_newline . "]\n";

# reverse and palindrome check
my $word   = "Perl";
my $phrase = "racecar";

my $reversed = reverse($word);
print "Original:   " . $word    . "\n";
print "Reversed:   " . $reversed . "\n";

if ($phrase eq reverse($phrase)) {
    print $phrase . " is a palindrome!\n";
}

