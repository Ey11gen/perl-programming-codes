#!/usr/bin/perl
use strict;
use warnings;

my $name   = "Alice";
my $age    = 29;
my $height = 1.6523;
my $salary = 52750;

printf("Name:   %s\n",   $name);
printf("Age:    %d\n",   $age);
printf("Height: %.2f\n", $height);
printf("Salary: \$%d\n", $salary);

printf("%-15s %5s %10s\n", "Name", "Age", "Salary");
printf("%-15s %5d %10d\n", "Alice",   29,  52750);
printf("%-15s %5d %10d\n", "Bob",     34,  61200);
printf("%-15s %5d %10d\n", "Carol",   27,  48900);

my $item     = "Widget";
my $quantity = 42;
my $unit     = 3.75;
my $total    = $quantity * $unit;

my $line = sprintf("%-20s  Qty: %4d  Unit: \$%6.2f  Total: \$%8.2f",
                   $item, $quantity, $unit, $total);

print $line . "\n";

#!/usr/bin/perl
use strict;
use warnings;

my $csv_line = "Alice,34,Madrid,Engineer";
my @fields   = split(/,/, $csv_line);

print "Name:       " . $fields[0] . "\n";
print "Age:        " . $fields[1] . "\n";
print "City:       " . $fields[2] . "\n";
print "Profession: " . $fields[3] . "\n";

my $sentence = "   The quick brown fox   ";
my @words    = split(" ", $sentence);

print "Number of words: " . scalar(@words) . "\n";

foreach my $word (@words) {
    print "Word: [" . $word . "]\n";
}

my @parts = ("one", "two", "three", "four");

my $joined_comma = join(", ", @parts);
my $joined_dash  = join(" - ", @parts);
my $joined_none  = join("", @parts);

print $joined_comma . "\n";
print $joined_dash  . "\n";
print $joined_none  . "\n";

# Split, modify, and rejoin
my $record = "Bob,28,London,Developer";
my @rec_fields = split(/,/, $record);
$rec_fields[2] = "Paris";
my $updated = join(",", @rec_fields);
print "Original: " . $record  . "\n";
print "Updated:  " . $updated . "\n";

#!/usr/bin/perl
use strict;
use warnings;

my $word     = "programming";
my $sentence = "Hello, World!";
my $empty    = "";

print "Length of word:     " . length($word)     . "\n";
print "Length of sentence: " . length($sentence) . "\n";
print "Length of empty:    " . length($empty)    . "\n";

my $text = "The quick brown fox";

my $first_three = substr($text, 0, 3);
my $word_quick  = substr($text, 4, 5);
my $from_brown  = substr($text, 10);

print "First three chars:  " . $first_three . "\n";
print "The word quick:     " . $word_quick  . "\n";
print "From position 10:   " . $from_brown  . "\n";

my $filename  = "report_2025_final.txt";
my $extension = substr($filename, -3);
my $last_four = substr($filename, -4);

print "Extension: " . $extension . "\n";
print "Last four: " . $last_four . "\n";

