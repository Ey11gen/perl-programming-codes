#!/usr/bin/perl
use strict;
use warnings;

my $password_attempts = 0;
my $max_attempts      = 3;

until ($password_attempts >= $max_attempts) {
    print "Enter password (attempt " . ($password_attempts + 1) . " of " . $max_attempts . ")\n";
    $password_attempts++;
}

print "Maximum attempts reached.\n";

