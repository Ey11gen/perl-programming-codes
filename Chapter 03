#!/usr/bin/perl
use strict;
use warnings;

for (my $i = 1; $i <= 10; $i++) {
    print "Count: " . $i . "\n";
}

# Using index to access array elements
my @names = ("Alice", "Bob", "Carol", "David");

for (my $i = 0; $i < scalar(@names); $i++) {
    print "Position " . $i . ": " . $names[$i] . "\n";
}

#!/usr/bin/perl
use strict;
use warnings;

my $age    = 25;
my $salary = 45000;

if ($age >= 18 && $salary >= 30000) {
    print "Loan application approved.\n";
} elsif ($age >= 18 && $salary < 30000) {
    print "Age requirement met, but salary is too low.\n";
} elsif ($age < 18) {
    print "Applicant must be at least 18 years old.\n";
} else {
    print "Application cannot be processed.\n";
}

#!/usr/bin/perl
use strict;
use warnings;

my $number = 10;

do {
    print "Current value: " . $number . "\n";
    $number++;
} while ($number < 5);

print "Done. Final value: " . $number . "\n";

