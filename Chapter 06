#!/usr/bin/perl
use strict;
use warnings;

my %scores = (
    "Alice" => 85,
    "Bob"   => 72,
    "Carol" => 91,
);

print "Before: Bob = " . $scores{"Bob"} . "\n";
$scores{"Bob"} = 88;
print "After:  Bob = " . $scores{"Bob"} . "\n";

$scores{"David"} = 79;
print "David added: " . $scores{"David"} . "\n";

my %population = (
    "Tokyo"  => 13_960_000,
    "Madrid" => 3_305_000,
    "London" => 8_982_000,
);

if (exists $population{"Madrid"}) {
    print "Madrid population: " . $population{"Madrid"} . "\n";
}

if (!exists $population{"Sydney"}) {
    print "Sydney is not in the hash.\n";
}

my %menu = (
    "burger" => 8.50,
    "pizza"  => 11.00,
    "salad"  => 6.75,
    "pasta"  => 9.25,
);

my $removed_price = delete $menu{"salad"};
print "Removed salad, price was: " . $removed_price . "\n";

if (!exists $menu{"salad"}) {
    print "Salad is no longer on the menu.\n";
}

print "Remaining items: " . join(", ", sort keys %menu) . "\n";

