#!/usr/bin/perl
use strict;
use warnings;

my $a = 20;
my $b = 6;

my $sum        = $a + $b;
my $difference = $a - $b;
my $product    = $a * $b;
my $quotient   = $a / $b;
my $remainder  = $a % $b;
my $power      = $a ** 2;

print "Sum:        " . $sum        . "\n";
print "Difference: " . $difference . "\n";
print "Product:    " . $product    . "\n";
print "Quotient:   " . $quotient   . "\n";
print "Remainder:  " . $remainder  . "\n";
print "Power:      " . $power      . "\n";

#!/usr/bin/perl
