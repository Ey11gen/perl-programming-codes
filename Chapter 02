#!/usr/bin/perl
use strict;
use warnings;

my $word      = "Perl";
my $separator = "-";

my $repeated  = $word x 3;
my $joined    = $word . " " . "Programming";
my $line      = $separator x 30;

print $repeated . "\n";
print $joined   . "\n";
print $line     . "\n";

# String append operator
my $message = "Dear Customer,\n";
$message .= "Your order has been received.\n";
$message .= "Thank you for shopping with us.\n";

print $message;

#!/usr/bin/perl
use strict;
use warnings;

my @values = (0, 1, -1, "", "0", "false", "hello", 0.1, undef);

foreach my $v (@values) {
    my $truth;
    if ($v) {
        $truth = "TRUE";
    } else {
        $truth = "FALSE";
    }
    my $display = defined($v) ? $v : "undef";
    print "Value: " . sprintf("%-8s", $display) . " -> " . $truth . "\n";
}

